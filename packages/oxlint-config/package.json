{
  "name": "@nelsonlaidev/oxlint-config",
  "version": "0.3.2",
  "homepage": "https://github.com/nelsonlaidev/config/tree/main/packages/oxlint-config",
  "bugs": {
    "url": "https://github.com/nelsonlaidev/config/issues"
  },
  "license": "MIT",
  "author": "Nelson Lai <me@nelsonlai.dev> (https://github.com/nelsonlaidev/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nelsonlaidev/config.git",
    "directory": "packages/oxlint-config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo dist",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "sync": "tsx scripts/sync-oxlint-eslint.ts && tsx scripts/generate-oxlint-plugin-snapshots.ts",
    "sync:check": "tsx scripts/sync-oxlint-eslint.ts --diff && tsx scripts/generate-oxlint-plugin-snapshots.ts --check",
    "sync:report": "tsx scripts/sync-oxlint-eslint.ts --report --write"
  },
  "dependencies": {
    "es-toolkit": "^1.49.0",
    "local-pkg": "^1.2.1"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@nelsonlaidev/eslint-plugin": "workspace:*",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "catalog:dev",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-command": "^3.5.2",
    "eslint-plugin-de-morgan": "^2.1.2",
    "eslint-plugin-import-zod": "^1.2.1",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev",
    "tsdown": "catalog:dev",
    "tsx": "^4.22.4",
    "vitest": "catalog:dev"
  },
  "peerDependencies": {
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@nelsonlaidev/eslint-plugin": "^0.2.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-command": "^3.5.2",
    "eslint-plugin-de-morgan": "^2.1.2",
    "eslint-plugin-import-zod": "^1.2.1",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "oxlint": ">=1.71.0",
    "oxlint-tsgolint": ">=0.23.1"
  },
  "peerDependenciesMeta": {
    "@eslint-react/eslint-plugin": {
      "optional": true
    },
    "eslint-plugin-better-tailwindcss": {
      "optional": true
    },
    "eslint-plugin-playwright": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
