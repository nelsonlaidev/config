{
  "name": "@nelsonlaidev/eslint-config",
  "version": "3.7.1",
  "homepage": "https://github.com/nelsonlaidev/config/blob/main/packages/eslint-config/README.md",
  "bugs": {
    "url": "https://github.com/nelsonlaidev/config/issues"
  },
  "license": "MIT",
  "author": "Nelson Lai <me@nelsonlai.dev> (https://github.com/nelsonlaidev/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nelsonlaidev/config.git",
    "directory": "packages/eslint-config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "types": "./dist/index.d.mts",
    "import": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:inspector": "eslint-config-inspector build --config ./eslint-inspector.config.ts",
    "clean": "rm -rf .turbo dist .eslint-config-inspector",
    "dev": "tsdown --watch",
    "dev:inspector": "eslint-config-inspector --config eslint-inspector.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@nelsonlaidev/eslint-plugin": "workspace:*",
    "@next/eslint-plugin-next": "^16.2.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/eslint-plugin": "^1.6.13",
    "eslint-config-flat-gitignore": "^2.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-command": "^3.5.2",
    "eslint-plugin-de-morgan": "^2.1.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-import-zod": "^1.2.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "local-pkg": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/config-inspector": "^1.5.0",
    "@nelsonlaidev/typescript-config": "workspace:*",
    "@types/node": "catalog:dev",
    "eslint": "catalog:dev",
    "tsdown": "catalog:dev"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  }
}
