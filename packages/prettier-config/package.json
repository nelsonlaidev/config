{
  "name": "@nelsonlaidev/prettier-config",
  "version": "0.3.1",
  "description": "Nelson Lai's Prettier config preset",
  "homepage": "https://github.com/nelsonlaidev/config/tree/main/packages/prettier-config",
  "bugs": {
    "url": "https://github.com/nelsonlaidev/config/issues"
  },
  "license": "MIT",
  "author": "Nelson Lai <me@nelsonlai.dev> (https://github.com/nelsonlaidev/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nelsonlaidev/config.git",
    "directory": "packages/prettier-config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nelsonlaidev/typescript-config": "workspace:*",
    "@types/node": "^24.11.0",
    "prettier": "^3.8.1",
    "tsdown": "catalog:dev"
  },
  "peerDependencies": {
    "prettier": "^3.0.0",
    "prettier-plugin-packagejson": "^2.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
