{
  "name": "@nelsonlaidev/eslint-plugin",
  "version": "0.2.1",
  "homepage": "https://github.com/nelsonlaidev/config/blob/main/packages/eslint-plugin/README.md",
  "bugs": {
    "url": "https://github.com/nelsonlaidev/config/issues"
  },
  "license": "MIT",
  "author": "Nelson Lai <me@nelsonlai.dev> (https://github.com/nelsonlaidev/)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nelsonlaidev/config.git",
    "directory": "packages/eslint-plugin"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "types": "./dist/index.d.mts",
    "import": "./dist/index.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf .turbo dist",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.57.2",
    "minimatch": "^10.2.4"
  },
  "devDependencies": {
    "@nelsonlaidev/typescript-config": "workspace:*",
    "@types/node": "catalog:dev",
    "@typescript-eslint/rule-tester": "^8.57.2",
    "eslint": "^10.1.0",
    "tsdown": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  }
}
