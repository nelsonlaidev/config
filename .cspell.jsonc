{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "useGitignore": true,
  "enableGlobDot": true,
  "enabledFileTypes": {
    "*": true,
  },
  "ignoreRandomStrings": true,
  "allowCompoundWords": true,
  "dictionaries": ["npm"],
  "ignorePaths": ["pnpm-lock.yaml", ".git"],
  "words": [
    "cjsx",
    "ctsx",
    "lookarounds",
    "misrefactored",
    "mjsx",
    "mtsx",
    "nelsonlaidev",
    "oxfmt",
    "Oxfmtrc",
    "oxlint",
    "polyfillio",
    "sonarjs",
    "sxzz",
    "TSES",
    "tsgolint",
    "uninvoked",
    "unsuffixed",
    "unthrown",
  ],
}
