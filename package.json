{
  "name": "@nelsonlaidev/config",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Nelson Lai <me@nelsonlai.dev> (https://github.com/nelsonlaidev/)",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm knip && pnpm lint:spell",
    "clean": "turbo clean && rm -rf .turbo",
    "dev": "turbo dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "knip": "knip",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:spell": "cspell .",
    "prepare": "lefthook install",
    "release": "changeset publish",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@nelsonlaidev/oxfmt-config": "workspace:*",
    "@nelsonlaidev/oxlint-config": "workspace:*",
    "@nelsonlaidev/typescript-config": "workspace:*",
    "@types/node": "^24.11.0",
    "cspell": "^9.7.0",
    "knip": "^5.85.0",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.30.3"
}
