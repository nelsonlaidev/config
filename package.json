{
  "name": "@nelsonlaidev/config",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Nelson Lai <me@nelsonlai.dev> (https://github.com/nelsonlaidev/)",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalogs": {
      "dev": {
        "@types/node": "^24.11.0",
        "eslint": "^10.1.0",
        "oxfmt": "^0.42.0",
        "oxlint": "^1.71.0",
        "oxlint-tsgolint": "^0.23.0",
        "tsdown": "^0.21.6",
        "vitest": "^4.1.2"
      }
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "check": "pnpm lint && pnpm typecheck && pnpm format:check && pnpm knip && pnpm lint:spell && pnpm sync:check",
    "clean": "turbo clean && rm -rf .turbo",
    "dev": "turbo dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "knip": "knip",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:spell": "cspell .",
    "prepare": "lefthook install",
    "release": "changeset publish",
    "sync": "turbo sync --filter=@nelsonlaidev/oxlint-config",
    "sync:check": "turbo sync:check --filter=@nelsonlaidev/oxlint-config",
    "sync:report": "turbo sync:report --filter=@nelsonlaidev/oxlint-config",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@nelsonlaidev/oxfmt-config": "workspace:*",
    "@nelsonlaidev/oxlint-config": "workspace:*",
    "@nelsonlaidev/typescript-config": "workspace:*",
    "@types/node": "catalog:dev",
    "cspell": "^9.7.0",
    "knip": "^6.1.0",
    "lefthook": "^2.1.4",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev",
    "turbo": "^2.8.21",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0"
}
